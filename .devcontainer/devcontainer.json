{
  "name": "mcpfleet",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": ["--name", "devc-mcpfleet", "-p", "3000:3000", "-p", "8080:8080"],
  "remoteUser": "ubuntu",
  "containerUser": "ubuntu",
  "updateRemoteUserUID": true,
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/mcpfleet,type=bind",
  "workspaceFolder": "/workspace/mcpfleet",
  "containerEnv": {
    "CODEX_HOME": "/home/ubuntu/.codex",
    "PNPM_HOME": "/home/ubuntu/.local/share/pnpm"
  },
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.ssh/known_hosts,target=/home/ubuntu/.ssh/known_hosts,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex,target=/home/ubuntu/.codex,type=bind",
    "source=mcpfleet-pnpm-store,target=/home/ubuntu/.local/share/pnpm/store,type=volume",
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash  .devcontainer/post-start.sh ${containerWorkspaceFolder}"
}
